{
  "name": "gaeludyr-cli",
  "version": "0.1.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "gaeludyr": "src/index.ts"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "bun build --compile src/index.ts --outfile gaeludyr",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx biome check src/",
    "check": "bun run lint && bun run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.12",
    "typescript": "^5.5.0"
  }
}
